# ===========================================
# AV Watch Backend — copy to .env
# ===========================================

APP_ENV=production
DEBUG=False

# Supabase Postgres (get from supabase.com → project settings → database)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Gemini API (get from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Reddit API (get from reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=avwatch:v1.0 (by /u/your_reddit_username)

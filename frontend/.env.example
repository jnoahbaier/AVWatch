# ===========================================
# AV Watch Frontend — copy to .env.local
# ===========================================

# Supabase (get from supabase.com → project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role — server-only; never expose to the browser. Required for POST /api/incidents/submit (IP hash on user reports).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox (account.mapbox.com → Access tokens)
# If your token has "URL restrictions" (e.g. production only), browser requests from
# http://localhost will be rejected. Fix one of:
#   • Use your unrestricted "Default public token" here for local dev only, or
#   • Edit the restricted token → add URL patterns, e.g.:
#       http://localhost:*
#       http://127.0.0.1:*
#     (include whatever port `next dev` uses: 3000, 3001, …)
# After changing this file, restart `npm run dev`.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-token-here

# Backend API URL (used by Next.js API proxy routes — server-side only)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Admin panel — Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-strong-random-secret
NEXTAUTH_URL=https://admin.avwatch.org

# Shared secret between Next.js and FastAPI for admin API calls
# Must match ADMIN_API_KEY in the backend .env
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-me-to-a-strong-random-secret
